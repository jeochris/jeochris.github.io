---
layout: default
---
<div class="post">
  <header class="post-header">
    <h1 class="post-title">
      {% if site.title == 'blank' %}
        <span class="font-weight-bold">{{ site.first_name }}{% if site.middle_name %} {{ site.middle_name }}{% endif %} {{ site.last_name }}</span>
      {% else %}
        {{ site.title }}
      {% endif %}
    </h1>
    {% if page.subtitle %}<p class="desc">{{ page.subtitle }}</p>{% endif %}
    <div style="margin-top: 0.5rem; font-size: 1rem; line-height: 2;">
      {% if site.data.socials.email %}
        <a href="mailto:{{ site.data.socials.email }}">[E-mail]</a>&nbsp;
      {% endif %}
      {% if site.data.socials.linkedin_username %}
        <a href="https://www.linkedin.com/in/{{ site.data.socials.linkedin_username }}" target="_blank">[LinkedIn]</a>&nbsp;
      {% endif %}
      {% if site.data.socials.github_username %}
        <a href="https://github.com/{{ site.data.socials.github_username }}" target="_blank">[GitHub]</a>&nbsp;
      {% endif %}
      {% if site.data.socials.scholar_userid %}
        <a href="https://scholar.google.com/citations?user={{ site.data.socials.scholar_userid }}" target="_blank">[Google Scholar]</a>&nbsp;
      {% endif %}
    </div>
  </header>

  <article>
    {% if page.profile %}
      <div class="profile float-{% if page.profile.align == 'left' %}left{% else %}right{% endif %}">
        {% if page.profile.image %}
          {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
          {% if page.profile.image_circular %}
            {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' %}
          {% else %}
            {% assign profile_image_class = 'img-fluid z-depth-1 rounded' %}
          {% endif %}
          {% capture sizes %}(min-width: {{ site.max_width }}) {{ site.max_width | minus: 30 | times: 0.24 }}px, (min-width: 576px) 24vw, 76vw"{% endcapture %}
          <div style="max-width: 80%;">
            {%
              include figure.liquid loading="eager" path=profile_image_path class=profile_image_class sizes=sizes alt=page.profile.image
              cache_bust=true
            %}
          </div>
        {% endif %}
      </div>
    {% endif %}

    <div class="clearfix" style="margin-top: 1rem;">{{ content }}</div>

    <!-- News -->
    {% if page.announcements and page.announcements.enabled %}
      <h2><a href="{{ '/news/' | relative_url }}" style="color: inherit">News</a></h2>
      {% include news.liquid limit=true %}
    {% endif %}

    <!-- Publications -->
    {% if page.selected_papers %}
      <h2><a href="{{ '/publications/' | relative_url }}" style="color: inherit">Publications</a></h2>
      <div class="publications">
        {% bibliography --group_by none %}
      </div>
    {% endif %}

    <!-- Selected Projects -->
    <h2><a href="{{ '/projects/' | relative_url }}" style="color: inherit">Selected Projects</a></h2>
    <div class="projects">
      {% assign sorted_projects = site.projects | sort: 'importance' | sort: 'year' | reverse %}
      {% assign current_year = '' %}
      {% for project in sorted_projects %}
        {% unless project.selected %}{% continue %}{% endunless %}
        {% if project.year %}
          {% assign project_year = project.year | toString %}
        {% else %}
          {% assign project_year = '' %}
        {% endif %}
        {% if project_year != current_year %}
          {% assign current_year = project_year %}
          {% if project_year != '' %}
            <h2 class="year">{{ project_year }}</h2>
          {% endif %}
        {% endif %}
        <div class="row mb-2 align-items-start">
          {% if project.img %}
            <div class="col-sm-3 abbr">
              {% if project.lead %}
                <abbr class="badge rounded w-100" style="background-color: #2e7d32;">Lead</abbr>
              {% endif %}
              <a href="{{ project.url | relative_url }}">
                {% include figure.liquid path=project.img class="img-fluid rounded z-depth-1" alt=project.title loading="eager" %}
              </a>
            </div>
            <div class="col-sm-9">
          {% else %}
            <div class="col-sm-12">
          {% endif %}
              <div class="mb-1" style="font-weight: bolder;"><a href="{{ project.url | relative_url }}" style="color: inherit">{{ project.title }}</a></div>
              {% if project.description %}
                <div class="mb-1">{{ project.description }}</div>
              {% endif %}
              {% if project.link %}
                <a href="{{ project.link }}" target="_blank" rel="noopener noreferrer" class="btn btn-sm z-depth-0" role="button"
                   style="color: var(--global-text-color); border: 1px solid var(--global-text-color); padding: 0.25rem 1rem; margin-left: 0;">Link</a>
              {% endif %}
            </div>
        </div>
      {% endfor %}
    </div>

  </article>
</div>
